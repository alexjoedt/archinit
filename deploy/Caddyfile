# Production Caddy config for VitePress (static + cleanUrls).
{
	admin off
	auto_https off
}

:80 {
	root * /usr/share/caddy
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	@static {
		path *.css *.js *.mjs *.map *.woff2 *.woff *.ttf *.ico *.svg *.png *.jpg *.jpeg *.webp *.gif
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	try_files {path} {path}.html {path}/ {path}/index.html /404.html
	file_server

	log {
		output stdout
		format console
	}
}
